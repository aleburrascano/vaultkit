{
  "name": "@aleburrascano/vaultkit",
  "version": "2.7.1",
  "type": "module",
  "description": "Obsidian wiki management — create, connect, and destroy vaults with GitHub Pages and Claude Code MCP.",
  "author": "Alessandro Burrascano <aleburrascano123@gmail.com>",
  "homepage": "https://github.com/aleburrascano/vaultkit#readme",
  "bugs": {
    "url": "https://github.com/aleburrascano/vaultkit/issues"
  },
  "bin": {
    "vaultkit": "dist/bin/vaultkit.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/post-build.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cleanup": "node scripts/test-cleanup.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "@mozilla/readability": "^0.6.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "jsdom": "^29.1.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "obsidian",
    "vault",
    "wiki",
    "claude-code",
    "mcp",
    "github-pages",
    "quartz"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aleburrascano/vaultkit.git"
  },
  "engines": {
    "node": ">=22"
  }
}
