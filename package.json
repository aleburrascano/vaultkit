{
  "name": "@aleburrascano/vaultkit",
  "version": "2.0.0",
  "type": "module",
  "description": "Obsidian wiki management — create, connect, and destroy vaults with GitHub Pages and Claude Code MCP.",
  "author": "Alessandro Burrascano <aleburrascano123@gmail.com>",
  "homepage": "https://github.com/aleburrascano/vaultkit#readme",
  "bugs": {
    "url": "https://github.com/aleburrascano/vaultkit/issues"
  },
  "bin": {
    "vaultkit": "bin/vaultkit.js"
  },
  "files": [
    "vault-init.sh",
    "vault-connect.sh",
    "vault-disconnect.sh",
    "vault-destroy.sh",
    "vault-pull.sh",
    "vault-update.sh",
    "vault-doctor.sh",
    "vault-verify.sh",
    "vault-status.sh",
    "vault-backup.sh",
    "vault-visibility.sh",
    "install.sh",
    "bin/vaultkit.js",
    "lib/_helpers.sh",
    "lib/mcp-start.js.tmpl",
    "lib/deploy.yml.tmpl"
  ],
  "scripts": {
    "lint": "shellcheck -x vault-*.sh install.sh lib/_helpers.sh",
    "check": "node --check bin/vaultkit.js && node -e \"new (require('vm').Script)(require('fs').readFileSync('lib/mcp-start.js.tmpl', 'utf8'), {filename: 'mcp-start.js.tmpl'})\"",
    "test": "npm run check && npm run lint"
  },
  "keywords": [
    "obsidian",
    "vault",
    "wiki",
    "claude-code",
    "mcp",
    "github-pages",
    "quartz"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aleburrascano/vaultkit.git"
  },
  "engines": {
    "node": ">=22"
  }
}
