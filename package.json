{
  "name": "@aleburrascano/vaultkit",
  "version": "2.0.2",
  "type": "module",
  "description": "Obsidian wiki management — create, connect, and destroy vaults with GitHub Pages and Claude Code MCP.",
  "author": "Alessandro Burrascano <aleburrascano123@gmail.com>",
  "homepage": "https://github.com/aleburrascano/vaultkit#readme",
  "bugs": {
    "url": "https://github.com/aleburrascano/vaultkit/issues"
  },
  "bin": {
    "vaultkit": "bin/vaultkit.js"
  },
  "files": [
    "bin/vaultkit.js",
    "src/",
    "lib/mcp-start.js.tmpl",
    "lib/deploy.yml.tmpl"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "cross-env VAULTKIT_LIVE_TEST=1 vitest run",
    "check": "node --check bin/vaultkit.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "commander": "^12.1.0",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "obsidian",
    "vault",
    "wiki",
    "claude-code",
    "mcp",
    "github-pages",
    "quartz"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aleburrascano/vaultkit.git"
  },
  "engines": {
    "node": ">=22"
  }
